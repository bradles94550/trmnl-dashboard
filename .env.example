# ── Inker ────────────────────────────────────────────────────────────────────
# PIN to access the Inker web UI at http://deepthought-ip:8080
INKER_ADMIN_PIN=changeme

# ── Home Assistant ────────────────────────────────────────────────────────────
# URL reachable from deepthought's Docker network
# Since HA runs on the same host, use the LAN IP (not localhost)
HA_URL=http://192.168.86.69:8123
# Long-lived access token — see docs/03-data-sources.md for how to generate
HA_TOKEN=REPLACE_WITH_HA_TOKEN

# ── Weather (Open-Meteo — no API key required) ────────────────────────────────
# Coordinates for your location
WEATHER_LAT=37.6879
WEATHER_LON=-121.7721

# ── Sports (ESPN unofficial API — no auth required) ───────────────────────────
# Examples:
#   sport=basketball  league=nba   team_id=11  (Golden State Warriors)
#   sport=baseball    league=mlb   team_id=137 (San Francisco Giants)
#   sport=football    league=nfl   team_id=25  (San Francisco 49ers)
# Find your team ID: https://site.api.espn.com/apis/site/v2/sports/SPORT/LEAGUE/teams
ESPN_SPORT=basketball
ESPN_LEAGUE=nba
ESPN_TEAM_ID=11

# ── Google Calendar (iCal URL — no OAuth required) ────────────────────────────
# In Google Calendar: Settings → [Calendar] → Integrate calendar → Secret address in iCal format
# Paste multiple URLs comma-separated for multiple family members
ICAL_URL=REPLACE_WITH_ICAL_URL

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_HA=300
CACHE_TTL_CALENDAR=900
CACHE_TTL_WEATHER=1800
CACHE_TTL_SPORTS=1800
